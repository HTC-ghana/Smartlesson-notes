    showOutput(`
      <div class="gen-empty">
        <span class="spinner" style="width:28px;height:28px;display:block;margin:0 auto .9rem;"></span>
        AI is writing your lesson notes…
      </div>`);

    const subjectData = SCHEME[subjectKey];
    const weekData    = subjectData.weeks[week];
    const ai          = await callAI(subjectData, weekData, classSize);

    renderLessonPlan(subjectData, weekData, classSize, week, ai);

    btn.disabled = false;
    btn.innerHTML = `
      <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
      Generate`;
  }

  /* ============================================================
     GENERATOR — call Anthropic API
  ============================================================ */
  async function callAI(subjectData, weekData, classSize) {
    const prompt = `You are an experienced Basic 7 teacher in Ghana.
Generate a structured lesson note in strict JSON (no markdown, no extra text).

Subject: ${subjectData.name}
Topic: ${weekData.topic}
Strand: ${weekData.strand}
Sub-strand: ${weekData.sub}
Content Standard Code: ${weekData.code}
Indicator: ${weekData.indicator} — ${weekData.indText}
Class Size: ${classSize}
Term: Third Term 2025/2026
Curriculum: Ghana Education Service (GES) / BBEKO

Return ONLY this JSON object:
{
  "performance_indicator": "By the end of the lesson, learners will be able to [measurable outcome based on the indicator].",
  "phase1": "Phase 1 Starter (5–8 min): Describe the starter activity to prepare learners' brains.",
  "phase2": "Phase 2 Main (25–30 min): Describe the main teaching steps, guided practice, independent activity, and embedded assessment.",
  "phase3": "Phase 3 Plenary (5 min): Describe how the lesson is closed and learning is consolidated.",
  "competencies": ["Competency 1", "Competency 2", "Competency 3"],
  "keywords": ["word1", "word2", "word3", "word4", "word5"],
  "tlr": ["Resource 1", "Resource 2", "Resource 3", "Resource 4"],
  "ref": "GES Basic 7 ${subjectData.name} Curriculum, Third Term 2025/2026, Indicator ${weekData.indicator}"
}`;

    try {
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1200,
          messages: [{ role: 'user', content: prompt }]
        })
      });
      const data = await response.json();
      const raw  = data.content.map(block => block.text || '').join('');
      return JSON.parse(raw.replace(/```json|```/g, '').trim());
    } catch (_) {
      /* Fallback if API fails */
      return {
        performance_indicator: `By the end of the lesson, learners will be able to ${weekData.indText.toLowerCase()}.`,
        phase1: `Open with a brief discussion: ask learners what they already know about "${weekData.topic}". Use 2–3 questions to activate prior knowledge and build curiosity.`,
        phase2: `Introduce "${weekData.topic}" on the whiteboard with clear explanations and relevant examples. Use the teaching-learning resources to demonstrate key concepts. Guide learners through a class exercise, then give an independent practice activity. Assess understanding through oral questioning and written tasks.`,
        phase3: `Summarise the main points of the lesson. Invite 2–3 learners to share one new thing they learned. Set a short take-home task to consolidate learning.`,
        competencies: ['Critical thinking and problem solving', 'Communication and collaboration', 'Cultural identity and global citizenship'],
        keywords: ['topic', 'concept', 'application', 'practice', 'assessment'],
        tlr: ['Textbook', 'Whiteboard and markers', 'Worksheets', 'Charts and diagrams'],
        ref: `GES Basic 7 ${subjectData.name} Curriculum, Third Term 2025/2026`
      };
    }
  }

  /* ============================================================
     GENERATOR — render lesson plan form (matches GES template)
  ============================================================ */
  function renderLessonPlan(subjectData, weekData, classSize, week, ai) {
    const today = new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });

    const chips = (arr, cls) =>
      arr.map(v => `<span class="chip ${cls}">${v}</span>`).join('');

    const html = `
      <!-- Lesson plan form -->
      <div class="lp" id="lessonPlanForm">

        <!-- Header row -->
        <div class="lp__top">
          <b>SUBJECT: ${subjectData.name.toUpperCase()}</b>
          <b>CLASS: Basic 7 &nbsp;&nbsp; CLASS SIZE: ${classSize}</b>
        </div>

        <!-- Meta row -->
        <div class="lp__meta">
          <div class="lp__meta-cell"><em>WEEK ENDING:</em></div>
          <div class="lp__meta-cell"><em>DATE:</em> ${today}</div>
          <div class="lp__meta-cell"><em>PERIOD:</em></div>
          <div class="lp__meta-cell"><em>LESSON:</em> Week ${week}</div>
        </div>

        <!-- Strand / Sub-strand -->
        <div class="lp__row-2">
          <div class="lp__cell">
            <span class="lp__cell-lbl">Strand</span>
            <span class="lp__cell-val">${weekData.strand}</span>
          </div>
          <div class="lp__cell">
            <span class="lp__cell-lbl">Sub-strand</span>
            <span class="lp__cell-val">${weekData.sub}</span>
          </div>
        </div>

        <!-- Indicator code / Content standard code -->
        <div class="lp__row-2">
          <div class="lp__cell">
            <span class="lp__cell-lbl">Indicator (code)</span>
            <span class="lp__cell-val lp__cell-val--code">${weekData.indicator}</span>
          </div>
          <div class="lp__cell">
            <span class="lp__cell-lbl">Content standard (code)</span>
            <span class="lp__cell-val lp__cell-val--code">${weekData.code}</span>
          </div>
        </div>

        <!-- Performance indicator -->
        <div class="lp__row-full">
          <span class="lp__cell-lbl">Performance Indicator</span>
          <p>${ai.performance_indicator}</p>
        </div>

        <!-- Core competencies / Key words -->
        <div class="lp__row-2">
          <div class="lp__cell">
            <span class="lp__cell-lbl">Core competencies</span>
            <div class="lp__chips">${chips(ai.competencies, 'chip--green')}</div>
          </div>
          <div class="lp__cell">
            <span class="lp__cell-lbl">Key words</span>
            <div class="lp__chips">${chips(ai.keywords, 'chip--amber')}</div>
          </div>
        </div>

        <!-- TLR / Reference -->
        <div class="lp__row-2" style="border-bottom:1px solid #ccc;">
          <div class="lp__cell">
            <span class="lp__cell-lbl">T.L.R.(s)</span>
            <span class="lp__cell-val">${ai.tlr.join(' · ')}</span>
          </div>
          <div class="lp__cell">
            <span class="lp__cell-lbl">Ref</span>
            <span class="lp__cell-val" style="font-size:10.5px;color:#555;">${ai.ref}</span>
          </div>
        </div>

        <!-- Three phases -->
        <div class="lp__phases">
          <div class="lp__phase">
            <div class="lp__phase-hdr">Phase 1 — Starter<br>(Preparing the brain for learning)</div>
            <div class="lp__phase-body">${ai.phase1}</div>
          </div>
          <div class="lp__phase">
            <div class="lp__phase-hdr">Phase 2 — Main<br>(New learning including assessment)</div>
            <div class="lp__phase-body">${ai.phase2}</div>
          </div>
          <div class="lp__phase">
            <div class="lp__phase-hdr">Phase 3 — Plenary / Reflection</div>
            <div class="lp__phase-body">${ai.phase3}</div>
          </div>
        </div>

      </div><!-- /.lp -->

      <!-- Action buttons -->
      <div class="gen-actions">
        <button class="gen-action-btn gen-action-btn--print" onclick="window.print()">🖨 Print</button>
        <button class="gen-action-btn gen-action-btn--pdf"   onclick="openPrintWindow()">⬇ Download PDF</button>
      </div>`;

    showOutput(html);
  }

  /* ============================================================
     HELPERS
  ============================================================ */
  function showOutput(html) {
    document.getElementById('genOutput').innerHTML = html;
  }

  /* Open a clean print window for PDF saving */
  function openPrintWindow() {
    const form = document.getElementById('lessonPlanForm');
    if (!form) return;

    const styles = `
      <style>
        body { font-family: Arial, sans-serif; font-size: 11pt; color: #111; margin: 16px; }
        h2   { font-size: 13pt; margin-bottom: 12px; }
        .lp  { border: 1.5px solid #000; border-radius: 0; overflow: hidden; font-size: 10.5pt; color: #111; }
        .lp__top { display: flex; justify-content: space-between; padding: 6px 10px; border-bottom: 1.5px solid #555; background: #f8f8f8; }
        .lp__meta { display: flex; border-bottom: 1px solid #ccc; }
        .lp__meta-cell { flex: 1; padding: 4px 8px; border-right: 1px solid #ccc; font-size: 10pt; }
        .lp__meta-cell:last-child { border-right: none; }
        .lp__row-2 { display: flex; border-bottom: 1px solid #ccc; }
        .lp__cell  { flex: 1; padding: 6px 8px; border-right: 1px solid #ccc; }
        .lp__cell:last-child { border-right: none; }
        .lp__cell-lbl { display: block; font-size: 8.5pt; font-weight: bold; text-transform: uppercase; letter-spacing: .04em; color: #444; margin-bottom: 3px; }
        .lp__cell-val--code { font-weight: bold; color: #0B6E50; }
        .lp__row-full { padding: 6px 8px; border-bottom: 1px solid #ccc; }
        .lp__chips { display: flex; flex-wrap: wrap; gap: 3px; margin-top: 4px; }
        .chip { display: inline-block; font-size: 8.5pt; padding: 2px 7px; border-radius: 12px; }
        .chip--green { background: #DFF5EC; color: #0B5E40; }
        .chip--amber { background: #FDF3D7; color: #7A5200; }
        .lp__phases { display: flex; }
        .lp__phase  { flex: 1; padding: 7px 9px; border-right: 1px solid #ccc; }
        .lp__phase:nth-child(2) { flex: 2; }
        .lp__phase:last-child { border-right: none; }
        .lp__phase-hdr { font-size: 8.5pt; font-weight: bold; color: #1DAD82; padding-bottom: 4px; margin-bottom: 5px; border-bottom: 1.5px solid #1DAD82; }
        .lp__phase-body { font-size: 10.5pt; line-height: 1.6; }
        em { font-style: normal; font-weight: 600; }
      </style>`;

    const win = window.open('', '_blank');
    win.document.write(`<!DOCTYPE html><html><head><title>Lesson Plan — LessonPro Ghana</title>${styles}</head><body>`);
    win.document.write('<h2>LESSON PLAN — LessonPro Ghana · Basic 7 · Third Term 2025/2026</h2>');
    win.document.write(form.outerHTML);
    win.document.write('</body></html>');
    win.document.close();
    win.focus();
    setTimeout(() => win.print(), 700);
  }
  </script>

