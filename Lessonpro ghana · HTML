  /* ============================================================
     NAVIGATION — mobile toggle
  ============================================================ */
  function toggleNav(btn) {
    const links = document.getElementById('navLinks');
    const open  = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    links.style.display = open ? '' : 'flex';
    links.style.flexDirection = open ? '' : 'column';
    links.style.position = open ? '' : 'absolute';
    links.style.top = open ? '' : 'var(--nav-h)';
    links.style.left = open ? '' : '0';
    links.style.right = open ? '' : '0';
    links.style.background = open ? '' : '#fff';
    links.style.padding = open ? '' : '1rem 2rem 1.5rem';
    links.style.borderBottom = open ? '' : '1px solid #CEEADE';
    links.style.boxShadow = open ? '' : '0 8px 24px rgba(0,0,0,.08)';
    links.style.zIndex = open ? '' : '999';
  }

  /* ============================================================
     FAQ — accordion
  ============================================================ */
  function toggleFaq(btn) {
    const item = btn.closest('.faq__item');
    const isOpen = item.classList.contains('faq__item--open');
    // Close all
    document.querySelectorAll('.faq__item--open').forEach(el => {
      el.classList.remove('faq__item--open');
      el.querySelector('.faq__trigger').setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      item.classList.add('faq__item--open');
      btn.setAttribute('aria-expanded', 'true');
    }
  }

